# アプリケーション設定
APP_NAME=FreelanceManager
APP_ENV=local

# データベース設定
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=freelance_manager
DB_USERNAME=freelance_user
DB_PASSWORD=freelance_password
DB_ROOT_PASSWORD=root_password

# バックエンド設定
BACKEND_PORT=8000
APP_KEY=

# フロントエンド設定
FRONTEND_PORT=3000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql

# Sanctum 設定
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost
